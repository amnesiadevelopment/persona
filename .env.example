# persona Configuration

# Profile storage file
PERSONA_PROFILES_FILE=profiles.json

# Browser data directory
PERSONA_DATA_DIR=persona_data

# Log directory
PERSONA_LOG_DIR=logs

# Log level (DEBUG, INFO, WARNING, ERROR)
PERSONA_LOG_LEVEL=INFO

# Proxy check timeout in seconds
PERSONA_PROXY_TIMEOUT=10

# Local API settings
PERSONA_API_HOST=127.0.0.1
PERSONA_API_PORT=8000
